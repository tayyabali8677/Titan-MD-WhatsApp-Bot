# ─────────────────────────────────────────────────────────────────────
# Titan MD — configuration template
# Copy to `config.env` and fill in the values you need. Anything left
# blank or commented out falls back to the default in `config.js`.
# ─────────────────────────────────────────────────────────────────────

# === REQUIRED for real-mode operation ===
SESSION_ID=
# Leave SESSION_ID blank to boot in MOCK MODE (safe for local testing).

# === Database ===
# Omit DATABASE_URL to use the built-in SQLite file at ./database.db.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# === Bot identity / prefix ===
BOT_NAME=Titan MD
PREFIX=^[.,!]
OWNER_NUMBER=
OWNER_NAME=TitanDev
SUDO=
MODE=private

# === Hosting platform integration ===
# HEROKU_APP_NAME=
# HEROKU_API_KEY=
# RENDER_NAME=
# RENDER_API_KEY=
# KOYEB=false
# KOYEB_NAME=
# KOYEB_API=
VPS=false

# === Behaviour flags ===
AUTO_UPDATE=true
ALWAYS_ONLINE=false
CMD_REACTION=true
REJECT_CALL=false
ANTI_CALL=false
ANTI_BOT=off
ANTI_DELETE=null
ANTI_VV=off
ANTI_LINK=true
AUTO_REPLY=false
AUTO_REACT=false
AUTO_TYPING=false
AUTO_RECORDING=false
AUTO_STATUS_VIEW=false
AUTO_STATUS_SEEN=false
PUBLIC_MODE=false
PM_BLOCKER=false

# === Sticker / branding ===
STICKER_PACKNAME=Titan MD;TitanDev
STICKER_NAME=Titan MD
PACK_NAME=Titan MD
PACK_AUTHER=TitanDev
DESCRIPTION=*© Powered by TitanDev — titanmd.site*
SUPPORT_GROUP=https://titanmd.site

# === Warnings ===
WARN_LIMIT=3

# === AI / external APIs (set only what you need) ===
GPT=free
# GEMINI_API_KEY=
# GROQ_API_KEY=
# OPENAI_API_KEY=
# ELEVENLAB_API_KEY=
# RMBG_KEY=
# IMGBB_KEY=
# TRUECALLER=
# YT_COOKIE=
# BING_COOKIE=

# === Theme & menu ===
THEME=TITAN
MENU=3
STYLE=0
LANGUAGE=en
TZ=UTC

# === Limits ===
MAX_UPLOAD=230

# === Reactions ===
CUSTOM_REACT=false
CUSTOM_REACT_EMOJIS=❤️,🔥,👍,😍,😂
REACT_EMOJIS=❤️,🔥,👍,😍,😂,😮,😎,🥰
OWNER_REACT=false
OWNER_EMOJIS=👑,💎,⭐,✨,🔥,💯

# === Logging ===
LOG_MSG=false
LOG_LEVEL=info
BAILEYS_LOG_LVL=silent
DISABLE_START_MESSAGE=false

# === Mock mode override ===
# Force MOCK_MODE even with a SESSION_ID (useful for tests).
# MOCK_MODE=true
