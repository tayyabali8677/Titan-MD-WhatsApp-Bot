{
  "name": "titan-md",
  "version": "1.0.0",
  "description": "Titan MD — WhatsApp MD user bot",
  "main": "index.js",
  "scripts": {
    "start": "pm2 start . --attach --name titan-md",
    "docker": "pm2-runtime start . --name titan-md",
    "stop": "pm2 stop titan-md",
    "dev": "node index.js",
    "mock": "MOCK_MODE=1 node index.js",
    "session": "node scripts/getSession.js",
    "session:pair": "node scripts/getSession.js --pair",
    "web": "node web/server.js",
    "test:help": "node scripts/simulate.js help",
    "test:shutdown": "node scripts/simulate.js shutdown",
    "postinstall": "node -e \"try { require('sharp') } catch (e) { process.exit(1); }\" || yarn add --ignore-engines sharp@0.34.5"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.0",
    "audio-decode": "^2.2.2",
    "axios": "^1.7.2",
    "bgutils-js": "^3.2.0",
    "browser-id3-writer": "^4.4.0",
    "cheerio": "^1.0.0-rc.12",
    "cookie": "^0.7.0",
    "cron": "^3.5.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "fastq": "^1.19.1",
    "file-type": "^18.2.1",
    "fluent-ffmpeg": "^2.1.2",
    "form-data": "^4.0.0",
    "fs-extra": "^11.1.0",
    "google-tts-api": "^2.0.2",
    "googleapis": "^126.0.1",
    "heroku-client": "^3.1.0",
    "jimp": "^1.6.0",
    "jsdom": "^24.0.0",
    "link-preview-js": "^3.0.4",
    "moment": "^2.29.4",
    "node-fetch": "3.2.2",
    "node-webpmux": "^3.1.4",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "pino": "^9.2.0",
    "pino-pretty": "^11.0.0",
    "pm2": "^6.0.0",
    "qrcode": "^1.5.3",
    "qrcode-reader": "^1.0.4",
    "qrcode-terminal": "^0.12.0",
    "sequelize": "^6.37.3",
    "sharp": "^0.34.5",
    "simple-git": "^3.16.1",
    "sqlite3": "^5.1.7",
    "translate-google-api": "^1.0.4",
    "youtubei.js": "^10.3.0"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=20.0.0"
  }
}
